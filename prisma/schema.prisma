// =============================================================================
// Rumah Pekerja Indonesia (RPI) — Prisma Schema
// Multi-tenant SaaS (Shared DB + tenant_id + Postgres RLS)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

enum GlobalRole {
  SUPERADMIN
  ADMIN
  PARTNER
  USER
}

enum TenantRole {
  OWNER
  ADMIN
  RECRUITER
  MEMBER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PROVISIONING
}

enum PlanTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ExperienceLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum LocationType {
  ONSITE
  HYBRID
  REMOTE
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  INTERVIEW
  OFFERED
  REJECTED
  WITHDRAWN
  HIRED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonContentType {
  VIDEO
  ARTICLE
  QUIZ
  ASSIGNMENT
  DOWNLOAD
}

enum EnrollmentStatus {
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum NotificationType {
  APPLICATION_UPDATE
  JOB_RECOMMEND
  COURSE_UPDATE
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  INVITE
  REVOKE
  PERMISSION_CHANGE
}

// =============================================================================
// TENANCY
// =============================================================================

model Tenant {
  id                      String       @id @default(cuid())
  slug                    String       @unique
  name                    String
  customDomain            String?      @unique @map("custom_domain")
  domainVerificationToken String?      @map("domain_verification_token")
  domainVerifiedAt        DateTime?    @map("domain_verified_at")
  planTier                PlanTier     @default(FREE) @map("plan_tier")
  status                  TenantStatus @default(PROVISIONING)
  ownerUserId             String?      @map("owner_user_id")
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")

  branding             Branding?
  users                UserTenant[]
  jobs                 Job[]
  courses              Course[]
  auditLogs            AuditLog[]
  subscriptions        Subscription[]
  invitations          Invitation[]
  teamMembers          TeamMember[]
  applications         Application[]
  stripeCustomerId     String?                @unique @map("stripe_customer_id")
  requireTwoFactor     Boolean                @default(false) @map("require_two_factor")
  webhooks             TenantWebhook[]
  apiKeys              TenantApiKey[]
  emailTemplates       TenantEmailTemplate[]
  interviewQuestions   InterviewQuestion[]
  retentionPolicies    AuditRetentionPolicy[]
  featureFlagOverrides FeatureFlagOverride[]

  @@index([planTier])
  @@index([status])
  @@map("tenants")
}

model Branding {
  id                  String   @id @default(cuid())
  tenantId            String   @unique @map("tenant_id")
  logoLight           String?  @map("logo_light")
  logoDark            String?  @map("logo_dark")
  favicon             String?
  primaryColor        String   @default("#0A2540") @map("primary_color")
  primaryForeground   String   @default("#FFFFFF") @map("primary_foreground")
  secondaryColor      String   @default("#C9A961") @map("secondary_color")
  secondaryForeground String   @default("#0A2540") @map("secondary_foreground")
  accentColor         String   @default("#635BFF") @map("accent_color")
  accentForeground    String   @default("#FFFFFF") @map("accent_foreground")
  backgroundColor     String   @default("#FFFFFF") @map("background_color")
  foregroundColor     String   @default("#0A2540") @map("foreground_color")
  mutedColor          String   @default("#F5F5F4") @map("muted_color")
  mutedForeground     String   @default("#6B7280") @map("muted_foreground")
  borderColor         String   @default("#E5E7EB") @map("border_color")
  destructiveColor    String   @default("#EF4444") @map("destructive_color")
  successColor        String   @default("#10B981") @map("success_color")
  warningColor        String   @default("#F59E0B") @map("warning_color")
  ringColor           String   @default("#C9A961") @map("ring_color")
  fontHeading         String   @default("Playfair Display") @map("font_heading")
  fontBody            String   @default("Inter") @map("font_body")
  radius              Int      @default(12)
  density             String   @default("normal")
  customCss           String?  @map("custom_css")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("brandings")
}

// =============================================================================
// AUTH (NextAuth + extensions)
// =============================================================================

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  emailVerified       DateTime?  @map("email_verified")
  passwordHash        String?    @map("password_hash")
  name                String?
  image               String?
  phone               String?
  bio                 String?
  headline            String?
  location            String?
  globalRole          GlobalRole @default(USER) @map("global_role")
  status              UserStatus @default(ACTIVE)
  lastLoginAt         DateTime?  @map("last_login_at")
  sessionsValidFrom   DateTime?  @map("sessions_valid_from")
  locale              String?
  timezone            String?
  username            String?    @unique
  profilePublic       Boolean    @default(false) @map("profile_public")
  referredByCode      String?    @map("referred_by_code")
  onboardingStep      Int        @default(0) @map("onboarding_step")
  onboardingCompleted Boolean    @default(false) @map("onboarding_completed")
  totpSecret          String?    @map("totp_secret")
  totpEnabledAt       DateTime?  @map("totp_enabled_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  accounts                 Account[]
  sessions                 Session[]
  tenants                  UserTenant[]
  jobsPosted               Job[]                    @relation("JobPostedBy")
  applications             Application[]
  savedJobs                SavedJob[]
  enrollments              Enrollment[]
  certificates             Certificate[]
  resumes                  Resume[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  teamLed                  TeamMember[]             @relation("TeamLead")
  memberOfTeam             TeamMember[]             @relation("TeamMember")
  coursesTaught            Course[]                 @relation("CourseInstructor")
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  emailChangeRequests      EmailChangeRequest[]
  totpRecoveryCodes        TotpRecoveryCode[]
  personalAccessTokens     PersonalAccessToken[]
  devices                  UserDevice[]
  notificationPref         NotificationPref?
  tenantApiKeysCreated     TenantApiKey[]           @relation("TenantApiKeyCreatedBy")
  emailDigestLogs          EmailDigestLog[]
  savedSearches            SavedSearch[]
  interviewsCreated        InterviewSchedule[]      @relation("InterviewCreatedBy")
  messagesSent             Message[]                @relation("MessageSender")
  scorecardsAuthored       InterviewScorecard[]     @relation("ScorecardAuthor")
  referrals                Referral[]
  referralUsages           ReferralUsage[]          @relation("ReferralReferred")
  quizAttempts             QuizAttempt[]            @relation("QuizAttemptUser")
  pushSubscriptions        PushSubscription[]
  interviewQuestions       InterviewQuestion[]      @relation("InterviewQuestionCreatedBy")
  calendarAccounts         CalendarAccount[]
  assessmentsCreated       Assessment[]             @relation("AssessmentCreatedBy")
  assessmentAttempts       AssessmentAttempt[]      @relation("AssessmentAttemptUser")
  moderationFlagsReported  ModerationFlag[]         @relation("ModerationReporter")
  moderationFlagsResolved  ModerationFlag[]         @relation("ModerationResolver")
  articlesAuthored         Article[]                @relation("ArticleAuthor")
  retentionPoliciesCreated AuditRetentionPolicy[]   @relation("RetentionPolicyCreatedBy")
  featureFlagsCreated      FeatureFlag[]            @relation("FeatureFlagCreatedBy")
  featureFlagOverrides     FeatureFlagOverride[]
  withdrawnApplications    Application[]            @relation("ApplicationWithdrawnBy")
  applicationNotesAuthored ApplicationNote[]        @relation("ApplicationNoteAuthor")
  applicationNoteMentions  ApplicationNoteMention[] @relation("ApplicationNoteMentionedUser")
  incidentsCreated         IncidentReport[]         @relation("IncidentCreatedBy")
  incidentUpdatesPosted    IncidentUpdate[]         @relation("IncidentUpdatePostedBy")
  maintenancesCreated      ScheduledMaintenance[]   @relation("MaintenanceCreatedBy")
  cookieConsents           CookieConsent[]

  @@index([globalRole])
  @@index([status])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  email     String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  requestIp String?   @map("request_ip")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model TenantWebhook {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  url       String
  secret    String
  events    String[]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@index([enabled])
  @@map("tenant_webhooks")
}

model WebhookDelivery {
  id           String    @id @default(cuid())
  webhookId    String    @map("webhook_id")
  event        String
  payload      Json
  status       String // pending | success | failed | dead_letter
  statusCode   Int?      @map("status_code")
  responseBody String?   @map("response_body")
  attempt      Int       @default(1)
  error        String?
  nextRetryAt  DateTime? @map("next_retry_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  deliveredAt  DateTime? @map("delivered_at")

  webhook TenantWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([status])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model TenantApiKey {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  createdById String?   @map("created_by_id")
  name        String
  tokenHash   String    @unique @map("token_hash")
  tokenPrefix String    @map("token_prefix")
  scopes      String[]
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  lastUsedIp  String?   @map("last_used_ip")
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("TenantApiKeyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([revokedAt])
  @@map("tenant_api_keys")
}

model EmailDigestLog {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  period String // e.g., "2026-W22"
  sentAt DateTime @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
  @@map("email_digest_logs")
}

model JobQuestion {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  label     String
  type      String // short_text | long_text | single_choice | multi_choice | file_url | yes_no
  required  Boolean  @default(false)
  options   Json? // array of strings for single_choice/multi_choice
  helpText  String?  @map("help_text")
  order     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job     Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  answers ApplicationAnswer[]

  @@index([jobId, order])
  @@map("job_questions")
}

model ApplicationAnswer {
  id            String   @id @default(cuid())
  applicationId String   @map("application_id")
  questionId    String   @map("question_id")
  value         String // canonical text representation; for multi_choice store JSON-encoded array
  createdAt     DateTime @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question    JobQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionId])
  @@index([applicationId])
  @@map("application_answers")
}

model ApplicationNote {
  id            String   @id @default(cuid())
  applicationId String   @map("application_id")
  authorId      String   @map("author_id")
  parentNoteId  String?  @map("parent_note_id")
  body          String
  pinned        Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application Application              @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      User                     @relation("ApplicationNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent      ApplicationNote?         @relation("NoteReplies", fields: [parentNoteId], references: [id], onDelete: Cascade)
  replies     ApplicationNote[]        @relation("NoteReplies")
  mentions    ApplicationNoteMention[]

  @@index([applicationId, createdAt])
  @@index([parentNoteId])
  @@map("application_notes")
}

model ApplicationNoteMention {
  id              String    @id @default(cuid())
  noteId          String    @map("note_id")
  mentionedUserId String    @map("mentioned_user_id")
  notifiedAt      DateTime? @map("notified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  note          ApplicationNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  mentionedUser User            @relation("ApplicationNoteMentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([noteId, mentionedUserId])
  @@index([mentionedUserId])
  @@map("application_note_mentions")
}

model IncidentReport {
  id               String    @id @default(cuid())
  title            String
  severity         String // minor | major | critical
  status           String // investigating | identified | monitoring | resolved
  affectedServices Json      @map("affected_services") // string[]
  startedAt        DateTime  @default(now()) @map("started_at")
  resolvedAt       DateTime? @map("resolved_at")
  createdById      String?   @map("created_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  createdBy User?            @relation("IncidentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updates   IncidentUpdate[]

  @@index([status, startedAt])
  @@index([startedAt])
  @@map("incident_reports")
}

model IncidentUpdate {
  id         String   @id @default(cuid())
  incidentId String   @map("incident_id")
  status     String // investigating | identified | monitoring | resolved
  message    String
  postedById String?  @map("posted_by_id")
  postedAt   DateTime @default(now()) @map("posted_at")

  incident IncidentReport @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  postedBy User?          @relation("IncidentUpdatePostedBy", fields: [postedById], references: [id], onDelete: SetNull)

  @@index([incidentId, postedAt])
  @@map("incident_updates")
}

model ScheduledMaintenance {
  id               String   @id @default(cuid())
  title            String
  description      String?
  affectedServices Json     @map("affected_services")
  scheduledStart   DateTime @map("scheduled_start")
  scheduledEnd     DateTime @map("scheduled_end")
  status           String   @default("planned") // planned | in_progress | completed | cancelled
  createdById      String?  @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  createdBy User? @relation("MaintenanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([scheduledStart])
  @@map("scheduled_maintenances")
}

model CookieConsent {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  sessionId  String   @map("session_id") // cookie ID — anon or per-session
  necessary  Boolean  @default(true)
  analytics  Boolean  @default(false)
  marketing  Boolean  @default(false)
  functional Boolean  @default(false)
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  version    Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("cookie_consents")
}

model FeatureFlag {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  description  String?
  type         String // boolean | percentage | segment
  enabled      Boolean  @default(false)
  percentage   Int      @default(0)
  segmentRules Json?    @map("segment_rules") // [{attr, op, values}]
  environments Json? // {dev: bool, staging: bool, prod: bool}
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy User?                 @relation("FeatureFlagCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  overrides FeatureFlagOverride[]

  @@index([enabled])
  @@map("feature_flags")
}

model FeatureFlagOverride {
  id        String   @id @default(cuid())
  flagId    String   @map("flag_id")
  userId    String?  @map("user_id")
  tenantId  String?  @map("tenant_id")
  value     Boolean
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  flag   FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  user   User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([flagId, userId, tenantId])
  @@index([flagId])
  @@map("feature_flag_overrides")
}

model StripeWebhookEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique @map("event_id")
  type        String
  payload     Json
  processedAt DateTime? @map("processed_at")
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@map("stripe_webhook_events")
}

model AuditRetentionPolicy {
  id             String   @id @default(cuid())
  scope          String // global | tenant
  tenantId       String?  @map("tenant_id")
  resourceType   String   @map("resource_type") // wildcard "*" or e.g. "login", "application.message"
  retentionDays  Int      @map("retention_days") // 90, 180, 365, 730, 0=forever
  archiveEnabled Boolean  @default(false) @map("archive_enabled")
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("RetentionPolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([scope, tenantId, resourceType])
  @@index([scope, tenantId])
  @@map("audit_retention_policies")
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  summary     String?
  body        String // markdown
  coverImage  String?   @map("cover_image")
  status      String    @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  authorId    String?   @map("author_id")
  tags        String[]
  viewCount   Int       @default(0) @map("view_count")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author User? @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([authorId])
  @@map("articles")
}

model CalendarAccount {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  provider      String // google | microsoft
  providerEmail String    @map("provider_email")
  calendarId    String?   @map("calendar_id")
  accessToken   String    @map("access_token")
  refreshToken  String?   @map("refresh_token")
  expiresAt     DateTime? @map("expires_at")
  scope         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  events CalendarEventMapping[]

  @@unique([userId, provider])
  @@index([userId])
  @@map("calendar_accounts")
}

model CalendarEventMapping {
  id                String   @id @default(cuid())
  interviewId       String   @unique @map("interview_id")
  calendarAccountId String   @map("calendar_account_id")
  externalEventId   String   @map("external_event_id")
  htmlLink          String?  @map("html_link")
  syncedAt          DateTime @default(now()) @map("synced_at")

  interview       InterviewSchedule @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  calendarAccount CalendarAccount   @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)

  @@index([calendarAccountId])
  @@map("calendar_event_mappings")
}

model Assessment {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  description  String
  category     String // technical | soft | language | cognitive
  durationMin  Int      @default(30) @map("duration_min")
  passingScore Int      @default(70) @map("passing_score")
  status       String   @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy User?                @relation("AssessmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]

  @@index([status])
  @@index([category, status])
  @@map("assessments")
}

model AssessmentQuestion {
  id           String @id @default(cuid())
  assessmentId String @map("assessment_id")
  text         String
  type         String // multiple_choice | true_false | multi_select
  order        Int

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  choices    AssessmentChoice[]

  @@index([assessmentId, order])
  @@map("assessment_questions")
}

model AssessmentChoice {
  id         String  @id @default(cuid())
  questionId String  @map("question_id")
  text       String
  isCorrect  Boolean @default(false) @map("is_correct")
  order      Int

  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
  @@map("assessment_choices")
}

model AssessmentAttempt {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  assessmentId String    @map("assessment_id")
  score        Int       @default(0)
  passed       Boolean   @default(false)
  answers      Json
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  user       User       @relation("AssessmentAttemptUser", fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId, assessmentId])
  @@index([assessmentId, completedAt])
  @@map("assessment_attempts")
}

model ModerationFlag {
  id           String    @id @default(cuid())
  resourceType String    @map("resource_type") // job | course | user | profile | message | application
  resourceId   String    @map("resource_id")
  reason       String // spam | inappropriate | misleading | copyright | other
  description  String?
  reportedById String?   @map("reported_by_id")
  status       String    @default("pending") // pending | reviewing | resolved | dismissed
  resolution   String?
  resolvedById String?   @map("resolved_by_id")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  reportedBy User? @relation("ModerationReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("ModerationResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([resourceType, resourceId])
  @@map("moderation_flags")
}

model InterviewQuestion {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  text        String
  category    String // technical | behavioral | situational | culture | other
  difficulty  Int      @default(3) // 1-5
  tags        String[]
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("InterviewQuestionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, category])
  @@index([tenantId, createdAt])
  @@map("interview_questions")
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  endpoint   String   @unique
  keys       Json
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Quiz {
  id           String   @id @default(cuid())
  lessonId     String   @unique @map("lesson_id")
  passingScore Int      @default(70) @map("passing_score")
  shuffle      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id     String @id @default(cuid())
  quizId String @map("quiz_id")
  text   String
  type   String // multiple_choice | true_false | multi_select
  order  Int

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices QuizChoice[]

  @@index([quizId, order])
  @@map("quiz_questions")
}

model QuizChoice {
  id         String  @id @default(cuid())
  questionId String  @map("question_id")
  text       String
  isCorrect  Boolean @default(false) @map("is_correct")
  order      Int

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
  @@map("quiz_choices")
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  quizId      String    @map("quiz_id")
  score       Int       @default(0)
  passed      Boolean   @default(false)
  answers     Json
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  user User @relation("QuizAttemptUser", fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId])
  @@index([quizId, completedAt])
  @@map("quiz_attempts")
}

model Referral {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String   @unique
  uses      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ReferralUsage[]

  @@index([userId])
  @@map("referrals")
}

model ReferralUsage {
  id             String   @id @default(cuid())
  referralId     String   @map("referral_id")
  referredUserId String   @unique @map("referred_user_id")
  appliedJobId   String?  @map("applied_job_id")
  createdAt      DateTime @default(now()) @map("created_at")

  referral     Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referredUser User     @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referralId])
  @@map("referral_usages")
}

model MessageThread {
  id            String    @id @default(cuid())
  applicationId String    @unique @map("application_id")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@map("message_threads")
}

model Message {
  id                String    @id @default(cuid())
  threadId          String    @map("thread_id")
  senderId          String    @map("sender_id")
  body              String
  readByCandidateAt DateTime? @map("read_by_candidate_at")
  readByRecruiterAt DateTime? @map("read_by_recruiter_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model InterviewScorecard {
  id             String   @id @default(cuid())
  interviewId    String   @unique @map("interview_id")
  authorId       String   @map("author_id")
  ratings        Json // array of {criterion: string, score: int 1-5}
  notes          String?
  recommendation String // strong_hire | hire | no_hire | strong_no_hire
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  interview InterviewSchedule @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  author    User              @relation("ScorecardAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@map("interview_scorecards")
}

model TenantEmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  status    String // ApplicationStatus enum value: REVIEWED | SHORTLISTED | INTERVIEW | OFFERED | HIRED | REJECTED
  subject   String
  body      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, status])
  @@index([tenantId])
  @@map("tenant_email_templates")
}

model InterviewSchedule {
  id             String    @id @default(cuid())
  applicationId  String    @map("application_id")
  scheduledAt    DateTime  @map("scheduled_at")
  durationMin    Int       @default(60) @map("duration_min")
  type           String    @default("video") // video | onsite | phone
  meetingUrl     String?   @map("meeting_url")
  location       String?
  notes          String?
  reminderSentAt DateTime? @map("reminder_sent_at")
  status         String    @default("scheduled") // scheduled | completed | cancelled | no_show
  stageOrder     Int       @default(1) @map("stage_order")
  stageName      String?   @map("stage_name") // "Technical", "HR", "Cultural Fit", "Final", custom
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  application   Application           @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdBy     User?                 @relation("InterviewCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  scorecard     InterviewScorecard?
  calendarEvent CalendarEventMapping?

  @@index([applicationId])
  @@index([scheduledAt])
  @@map("interview_schedules")
}

model SavedSearch {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  name           String
  query          String?
  categorySlug   String?   @map("category_slug")
  location       String?
  employmentType String?   @map("employment_type")
  emailAlerts    Boolean   @default(true) @map("email_alerts")
  lastAlertAt    DateTime? @map("last_alert_at")
  lastAlertCount Int       @default(0) @map("last_alert_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([emailAlerts, lastAlertAt])
  @@map("saved_searches")
}

model NotificationPref {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  emailLoginAlert    Boolean  @default(true) @map("email_login_alert")
  emailSecurityEvent Boolean  @default(true) @map("email_security_event")
  emailInvitation    Boolean  @default(true) @map("email_invitation")
  emailMarketing     Boolean  @default(false) @map("email_marketing")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_prefs")
}

model UserDevice {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  fingerprint String
  userAgent   String    @map("user_agent")
  ipFirstSeen String?   @map("ip_first_seen")
  ipLastSeen  String?   @map("ip_last_seen")
  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  loginCount  Int       @default(1) @map("login_count")
  alertSentAt DateTime? @map("alert_sent_at")
  revokedAt   DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
  @@map("user_devices")
}

model PersonalAccessToken {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  tokenHash   String    @unique @map("token_hash")
  tokenPrefix String    @map("token_prefix")
  scopes      String[]
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  lastUsedIp  String?   @map("last_used_ip")
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revokedAt])
  @@map("personal_access_tokens")
}

model EmailChangeRequest {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  oldEmail  String    @map("old_email")
  newEmail  String    @map("new_email")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  requestIp String?   @map("request_ip")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_change_requests")
}

model TotpRecoveryCode {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  codeHash  String    @unique @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("totp_recovery_codes")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  requestIp String?   @map("request_ip")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// =============================================================================
// MEMBERSHIPS / TEAMS / INVITATIONS
// =============================================================================

model UserTenant {
  id       String     @id @default(cuid())
  userId   String     @map("user_id")
  tenantId String     @map("tenant_id")
  role     TenantRole @default(MEMBER)
  status   String     @default("active")
  joinedAt DateTime   @default(now()) @map("joined_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId, role])
  @@map("user_tenants")
}

model TeamMember {
  id        String     @id @default(cuid())
  tenantId  String     @map("tenant_id")
  leadId    String     @map("lead_id")
  memberId  String     @map("member_id")
  role      TenantRole @default(RECRUITER)
  createdAt DateTime   @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   User   @relation("TeamLead", fields: [leadId], references: [id], onDelete: Cascade)
  member User   @relation("TeamMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, memberId])
  @@index([tenantId, leadId])
  @@map("team_members")
}

model Invitation {
  id         String     @id @default(cuid())
  tenantId   String     @map("tenant_id")
  email      String
  role       TenantRole
  token      String     @unique
  expiresAt  DateTime   @map("expires_at")
  acceptedAt DateTime?  @map("accepted_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, email])
  @@map("invitations")
}

// =============================================================================
// JOBS
// =============================================================================

model JobCategory {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  icon     String
  parentId String? @map("parent_id")

  parent   JobCategory?  @relation("JobCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children JobCategory[] @relation("JobCategoryHierarchy")
  jobs     Job[]

  @@map("job_categories")
}

model Job {
  id               String          @id @default(cuid())
  tenantId         String          @map("tenant_id")
  title            String
  slug             String
  description      String
  responsibilities String?
  requirements     String?
  benefits         String?
  salaryMin        Int?            @map("salary_min")
  salaryMax        Int?            @map("salary_max")
  salaryCurrency   String          @default("IDR") @map("salary_currency")
  salaryPeriod     String          @default("month") @map("salary_period")
  employmentType   EmploymentType  @default(FULL_TIME) @map("employment_type")
  experienceLevel  ExperienceLevel @default(MID) @map("experience_level")
  location         String
  locationType     LocationType    @default(ONSITE) @map("location_type")
  categoryId       String?         @map("category_id")
  tags             String[]
  status           JobStatus       @default(DRAFT)
  postedById       String          @map("posted_by_id")
  views            Int             @default(0)
  publishedAt      DateTime?       @map("published_at")
  expiredAt        DateTime?       @map("expired_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     JobCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  postedBy     User          @relation("JobPostedBy", fields: [postedById], references: [id], onDelete: Cascade)
  applications Application[]
  savedBy      SavedJob[]
  questions    JobQuestion[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([employmentType])
  @@index([locationType])
  @@map("jobs")
}

model Application {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  jobId       String            @map("job_id")
  userId      String            @map("user_id")
  resumeUrl   String?           @map("resume_url")
  coverLetter String?           @map("cover_letter")
  status      ApplicationStatus @default(APPLIED)
  notes       String?
  appliedAt   DateTime          @default(now()) @map("applied_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  aiScore          Int?                @map("ai_score")
  aiTags           String[]            @map("ai_tags")
  aiScoreBreakdown Json?               @map("ai_score_breakdown")
  aiScoredAt       DateTime?           @map("ai_scored_at")
  withdrawnAt      DateTime?           @map("withdrawn_at")
  withdrawReason   String?             @map("withdraw_reason")
  withdrawnById    String?             @map("withdrawn_by_id")
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job              Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawnBy      User?               @relation("ApplicationWithdrawnBy", fields: [withdrawnById], references: [id], onDelete: SetNull)
  interviews       InterviewSchedule[]
  messageThread    MessageThread?
  answers          ApplicationAnswer[]
  recruiterNotes   ApplicationNote[]

  @@unique([jobId, userId])
  @@index([tenantId, status])
  @@index([userId, status])
  @@map("applications")
}

model SavedJob {
  id      String   @id @default(cuid())
  userId  String   @map("user_id")
  jobId   String   @map("job_id")
  savedAt DateTime @default(now()) @map("saved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model Resume {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  fileUrl   String?  @map("file_url")
  content   Json?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPrimary])
  @@map("resumes")
}

// =============================================================================
// LMS
// =============================================================================

model Course {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  title         String
  slug          String
  description   String
  thumbnail     String?
  level         CourseLevel
  durationHours Int          @map("duration_hours")
  instructorId  String?      @map("instructor_id")
  status        CourseStatus @default(DRAFT)
  publishedAt   DateTime?    @map("published_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor   User?         @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: SetNull)
  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("courses")
}

model Module {
  id          String @id @default(cuid())
  courseId    String @map("course_id")
  title       String
  order       Int
  durationMin Int    @default(0) @map("duration_min")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, order])
  @@map("modules")
}

model Lesson {
  id          String            @id @default(cuid())
  moduleId    String            @map("module_id")
  title       String
  contentType LessonContentType @map("content_type")
  contentUrl  String?           @map("content_url")
  contentBody String?           @map("content_body")
  order       Int
  durationMin Int               @default(0) @map("duration_min")

  module   Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  quiz     Quiz?

  @@index([moduleId, order])
  @@map("lessons")
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  courseId    String           @map("course_id")
  status      EnrollmentStatus @default(IN_PROGRESS)
  progress    Int              @default(0)
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([userId, courseId])
  @@index([userId, status])
  @@map("enrollments")
}

model LessonProgress {
  id           String    @id @default(cuid())
  enrollmentId String    @map("enrollment_id")
  lessonId     String    @map("lesson_id")
  completedAt  DateTime? @map("completed_at")
  watchSeconds Int       @default(0) @map("watch_seconds")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progresses")
}

model Certificate {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  courseId          String?  @map("course_id")
  jobApplicationId  String?  @map("job_application_id")
  certificateNumber String?  @unique @map("certificate_number")
  title             String
  fileUrl           String   @map("file_url")
  issuedAt          DateTime @default(now()) @map("issued_at")
  issuer            String

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("certificates")
}

// =============================================================================
// NOTIFICATIONS / AUDIT / BILLING
// =============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String?     @map("tenant_id")
  userId     String      @map("user_id")
  action     AuditAction
  resource   String
  resourceId String?     @map("resource_id")
  metadata   Json?
  ip         String?
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

model Subscription {
  id                   String   @id @default(cuid())
  tenantId             String   @map("tenant_id")
  plan                 PlanTier
  status               String
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("subscriptions")
}
