# ----------------------------------------------------------------------------
# Rumah Pekerja Indonesia (RPI) SaaS — Environment variables
# Copy this file to `.env.local` and fill in values for local development.
# ----------------------------------------------------------------------------

# ---------- Database ----------
DATABASE_URL="postgresql://user:password@localhost:5432/rumahpekerja?schema=public"

# ---------- NextAuth.js ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-strong-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---------- OAuth providers ----------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Public app config ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# ---------- Storage ----------
# One of: "local" | "r2". "local" writes to public/uploads (dev only — disk is
# ephemeral on Vercel). For "r2", ALL five R2_* vars below are required;
# uploads silently fall back to a "belum dikonfigurasi" error otherwise.
STORAGE_PROVIDER="local"
# Cloudflare R2 (S3-compatible). Endpoint is derived as
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public base URL the bucket is served from (r2.dev or a custom domain),
# no trailing slash. Stored file URLs are "<R2_PUBLIC_URL>/<key>".
R2_PUBLIC_URL=""

# ---------- AI (Anthropic / Claude) ----------
# Optional. When empty, AI features (e.g. the job-description generator) fall
# back to their deterministic template output — the app works without a key.
# Set to enable real LLM generation. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=""

# ---------- Cache / queues ----------
REDIS_URL="redis://localhost:6379"

# ---------- Email ----------
RESEND_API_KEY=""

# ---------- Observability ----------
# Log verbosity: debug | info | warn | error (default: info in prod, debug otherwise)
LOG_LEVEL=""
# Optional ingestion endpoint for captured exceptions/events (provider-agnostic:
# Sentry tunnel, PostHog, Logflare, or a custom collector). When unset, captures
# are structured-logged only. Use NEXT_PUBLIC_* to also forward client errors.
OBSERVABILITY_DSN=""
NEXT_PUBLIC_OBSERVABILITY_DSN=""
