# ----------------------------------------------------------------------------
# Rumah Pekerja Indonesia (RPI) SaaS — Environment variables
# Copy this file to `.env.local` and fill in values for local development.
# ----------------------------------------------------------------------------

# ---------- Database ----------
DATABASE_URL="postgresql://user:password@localhost:5432/rumahpekerja?schema=public"

# ---------- NextAuth.js ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-strong-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---------- OAuth providers ----------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Public app config ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# ---------- Storage ----------
# One of: "local" | "r2"
STORAGE_PROVIDER="local"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ---------- Cache / queues ----------
REDIS_URL="redis://localhost:6379"

# ---------- Email ----------
RESEND_API_KEY=""

# ---------- Observability ----------
# Log verbosity: debug | info | warn | error (default: info in prod, debug otherwise)
LOG_LEVEL=""
# Optional ingestion endpoint for captured exceptions/events (provider-agnostic:
# Sentry tunnel, PostHog, Logflare, or a custom collector). When unset, captures
# are structured-logged only. Use NEXT_PUBLIC_* to also forward client errors.
OBSERVABILITY_DSN=""
NEXT_PUBLIC_OBSERVABILITY_DSN=""
